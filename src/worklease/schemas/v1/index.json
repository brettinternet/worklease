{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worklease.dev/schemas/v1/index.json",
  "title": "Worklease schema version 1",
  "description": "Published response schemas for the worklease Python and CLI compatibility surface.",
  "type": "object",
  "required": ["version", "common", "cli", "commands"],
  "properties": {
    "version": {"const": 1},
    "common": {"const": "common.json"},
    "cli": {"const": "commands.json"},
    "commands": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "parse", "version", "key", "policy-list", "policy-describe",
          "acquire", "bundle-acquire", "acquire-bundle",
          "status", "status-verbose", "bundle-status", "inspect-bundle", "status-bundle",
          "inspect-operation", "reconcile-operation", "list", "heartbeat",
          "checkpoint", "transfer", "release", "bundle-heartbeat", "heartbeat-bundle",
          "bundle-release", "release-bundle", "exec", "bundle-exec",
          "exec-bundle", "replace-file"
        ]
      }
    }
  },
  "additionalProperties": false
}
